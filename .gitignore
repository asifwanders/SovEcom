# --- Project-local planning + agent docs (not tracked in this repo) ---
# NOTE: no quotes — gitignore treats them literally; spaces match as-is.
plan & documentation/
AGENTS.md
CLAUDE.md

# --- Dependencies ---
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# --- Build output ---
dist/
build/
out/
.next/
.turbo/
.astro/
*.tsbuildinfo

# --- Test / coverage ---
coverage/
.nyc_output/
*.lcov

# --- E2E (Playwright + Lighthouse-CI) generated artifacts ---
playwright-report/
test-results/
.lighthouseci/
/blob-report/
/playwright/.cache/

# --- Logs ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- Environment & secrets ---
.env
.env.*
!.env.example
*.key
/data/master.key
*.pem

# --- Caches ---
.cache/
.eslintcache
.parcel-cache/

# --- IDE / editor ---
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
*.swp
*.swo
*~

# --- OS artifacts ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# --- Misc tooling ---
.claude-flow/
.ruflo/

# --- Deploy/test-server config (local only, never committed) ---
.deploy/

# --- Bundled-module build artifacts (regenerated by `pnpm pack:bundled-modules`) ---
# The packed `.tgz` + copied `<id>.module.json` the API reads at runtime. Build output,
# never committed — the catalog JSON (apps/api/src/modules/bundled-modules.catalog.json) is
# the tracked source of truth; the pack step regenerates these.
apps/api/bundled-modules/

# Benchmark run artifacts
scripts/benchmarks/bench-results.*

# Docs-screenshot capture: local dev data dir + Playwright report/results
apps/api/.dev-data/
**/playwright-report/

# Generated API-reference specs (split from apps/api/openapi.json by docs/scripts/split-openapi.mjs)
docs/src/openapi/
