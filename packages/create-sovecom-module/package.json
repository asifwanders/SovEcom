{
  "name": "create-sovecom-module",
  "version": "0.0.1",
  "private": true,
  "license": "MIT",
  "description": "Non-interactive scaffolder for a SovEcom module starter.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "bin": {
    "create-sovecom-module": "./dist/cli.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@sovecom/module-sdk": "workspace:*",
    "@types/node": "^24.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.0.0"
  }
}
