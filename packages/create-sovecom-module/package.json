{
  "name": "create-sovecom-module",
  "version": "1.0.0-rc.1",
  "license": "MIT",
  "description": "Non-interactive scaffolder for a SovEcom module starter.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "create-sovecom-module": "./dist/cli.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm build"
  },
  "devDependencies": {
    "@sovecom/module-sdk": "workspace:*",
    "@types/node": "^24.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/asifwanders/SovEcom.git",
    "directory": "packages/create-sovecom-module"
  },
  "homepage": "https://github.com/asifwanders/SovEcom",
  "bugs": {
    "url": "https://github.com/asifwanders/SovEcom/issues"
  }
}
