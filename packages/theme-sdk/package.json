{
  "name": "@sovecom/theme-sdk",
  "version": "1.0.1",
  "license": "MIT",
  "description": "Public author-facing contract SDK for the SovEcom theme ecosystem",
  "repository": {
    "type": "git",
    "url": "https://github.com/asifwanders/SovEcom.git",
    "directory": "packages/theme-sdk"
  },
  "homepage": "https://github.com/asifwanders/SovEcom#readme",
  "bugs": {
    "url": "https://github.com/asifwanders/SovEcom/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "pnpm build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@sovecom/module-sdk": "workspace:*",
    "semver": "^7.8.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/semver": "^7.7.1",
    "typescript": "^5.4.0",
    "vitest": "^4.1.9"
  }
}
