{
  "name": "@sovecom/client-js",
  "version": "1.0.1",
  "license": "AGPL-3.0-only",
  "description": "Typed fetch client for the SovEcom storefront API",
  "repository": {
    "type": "git",
    "url": "https://github.com/asifwanders/SovEcom.git",
    "directory": "packages/client-js"
  },
  "homepage": "https://github.com/asifwanders/SovEcom#readme",
  "bugs": {
    "url": "https://github.com/asifwanders/SovEcom/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "pnpm build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "generate": "openapi-typescript ../../apps/api/openapi.json -o src/generated/api.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "openapi-typescript": "^7.4.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.9"
  }
}
