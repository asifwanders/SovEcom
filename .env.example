# SovEcom Environment Configuration
# Copy this file to .env and fill in your values

# API
API_PORT=3000

# Database
DATABASE_URL=postgres://sovecom:devpassword@localhost:5432/sovecom_dev

# Redis
REDIS_URL=redis://localhost:6379

# Meilisearch
MEILISEARCH_URL=http://localhost:7700
MEILI_MASTER_KEY=devkey

# Storefront
NEXT_PUBLIC_API_URL=http://localhost:3000

# Secrets (generate strong values for production)
# MASTER_KEY=<generate with openssl rand -hex 32>
# JWT_SECRET=<generate with openssl rand -hex 32>
