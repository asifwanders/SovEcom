# =============================================================================
# SovEcom Production Environment Variables
# Copy to .env and fill in all values before running docker compose up
# =============================================================================

# ── PostgreSQL ───────────────────────────────────────────────────────────────
# Strong random password (min 32 chars)
POSTGRES_PASSWORD=change-me-to-a-strong-random-password

# ── Meilisearch ──────────────────────────────────────────────────────────────
# Master key: min 16 chars, used to generate all API keys
MEILI_MASTER_KEY=change-me-to-a-strong-random-key

# ── API Secrets ──────────────────────────────────────────────────────────────
# JWT signing secret: min 32 bytes (256 bits) of entropy
JWT_SECRET=change-me-to-a-strong-jwt-secret-at-least-32-bytes

# MASTER_KEY: base64-encoded 32-byte AES key. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
MASTER_KEY=change-me-to-base64-encoded-32-byte-aes-key=

# STORAGE_SIGNING_SECRET: min 32 bytes hex/random string
STORAGE_SIGNING_SECRET=change-me-to-a-strong-storage-signing-secret-at-least-32-bytes

# GUEST_TOKEN_SECRET (optional): dedicated HMAC key for sov_guest cookies. Min 32 bytes. When
# set, it is preferred over STORAGE_SIGNING_SECRET for guest token signing, allowing independent
# key rotation. Must NOT be weak (all-whitespace or shorter than 32 bytes) or it is ignored.
# GUEST_TOKEN_SECRET=change-me-to-a-strong-dedicated-guest-token-secret-32-bytes

# GUEST_COOKIE_DOMAIN (optional): explicit Domain= attribute for the sov_guest cookie. Set this
# when STORE_ORIGIN falls on a shared public-suffix host (e.g. *.sovecom.cloud, *.herokuapp.com)
# where auto-detection returns host-only (no Domain attr) but you still want the cookie to span
# subdomains. Set to the registrable part only (e.g. tenant.sovecom.cloud). Without this, auto-
# detection via the Public Suffix List is used; if it cannot determine a safe registrable domain
# the cookie defaults to host-only.
# GUEST_COOKIE_DOMAIN=

# AUDIT_EMAIL_SALT: salt for hashing admin email in audit log. Min 16 chars. Generate with:
#   openssl rand -hex 16
AUDIT_EMAIL_SALT=change-me-generate-with-openssl-rand-hex-16

# ── Redis ────────────────────────────────────────────────────────────────────
# Redis password for defense-in-depth. Generate with:
#   openssl rand -hex 24
REDIS_PASSWORD=change-me-generate-with-openssl-rand-hex-24

# ── Domain ───────────────────────────────────────────────────────────────────
# Your public domain. Caddy will obtain Let's Encrypt certs for:
#   {SOVECOM_DOMAIN}, admin.{SOVECOM_DOMAIN}, setup.{SOVECOM_DOMAIN}, api.{SOVECOM_DOMAIN}
# For nip.io testing use e.g.: 203-0-113-1.nip.io
SOVECOM_DOMAIN=<your-domain>

# ── Runtime API base URL ──────────────────────────────────────────────────────
# Injected at container START (not baked at build), so one Docker image works on any domain.
# docker-compose.yml derives this automatically from SOVECOM_DOMAIN, so you usually don't
# need to set it explicitly — it is documented here for standalone docker run usage:
#
#   docker run -e API_BASE_URL=https://api.mystore.com ghcr.io/your-org/sovecom-admin:latest
#
# For the storefront this is the PUBLIC-facing API URL (browser → API). SSR fetches inside the
# compose network can also read it (they share the same env var in docker-compose.yml).
# API_BASE_URL=https://api.${SOVECOM_DOMAIN}

# ── SMTP (optional — MailHog used when profile=verify) ───────────────────────
# Leave blank to use MailHog (compose profile: verify)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@<your-domain>

# ── Stripe (optional — stores without Stripe still boot) ─────────────────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
