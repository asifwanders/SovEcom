# Production Caddyfile - parameterised by SOVECOM_DOMAIN env var.
# Caddy obtains real Let's Encrypt TLS certificates automatically.

{$SOVECOM_DOMAIN} {
	reverse_proxy storefront:3001
	log {
		output stdout
		format json
	}
}

admin.{$SOVECOM_DOMAIN} {
	reverse_proxy admin:80
	log {
		output stdout
		format json
	}
}

setup.{$SOVECOM_DOMAIN} {
	reverse_proxy setup:80
	log {
		output stdout
		format json
	}
}

api.{$SOVECOM_DOMAIN} {
	reverse_proxy api:3000
	log {
		output stdout
		format json
	}
}
