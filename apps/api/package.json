{
  "name": "@sovecom/api",
  "version": "0.0.1",
  "private": true,
  "license": "AGPL-3.0-only",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "dev": "nest start --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "jest --config jest.config.js",
    "test:e2e": "jest --config jest.e2e.config.js",
    "openapi:dump": "jest --config jest.openapi.config.js --runInBand",
    "test:integration": "jest --config jest.integration.config.js",
    "test:concurrency": "jest --config jest.concurrency.config.js",
    "test:watch": "jest --config jest.config.js --watch",
    "test:cov": "jest --config jest.config.js --coverage",
    "db:generate": "drizzle-kit generate",
    "migrate:up": "drizzle-kit migrate",
    "seed": "ts-node src/database/seed.ts",
    "clean": "rm -rf dist",
    "reindex": "ts-node -r tsconfig-paths/register scripts/reindex.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1064.0",
    "@aws-sdk/s3-request-presigner": "^3.1064.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/event-emitter": "^3.1.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.4.4",
    "@sovecom/module-sdk": "workspace:*",
    "@sovecom/theme-sdk": "workspace:*",
    "argon2": "^0.44.0",
    "cookie-parser": "^1.4.7",
    "drizzle-orm": "^0.45.2",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "meilisearch": "^0.58.0",
    "nestjs-zod": "^5.4.0",
    "nodemailer": "^9.0.1",
    "otplib": "^13.4.1",
    "pdfkit": "^0.19.1",
    "postgres": "^3.4.9",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sharp": "^0.34.5",
    "stripe": "^22.2.0",
    "tar": "^7.5.16",
    "uuidv7": "^1.2.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.0.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pdfkit": "^0.17.6",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^7.2.0",
    "drizzle-kit": "^0.31.10",
    "jest": "^29.7.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.3.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
