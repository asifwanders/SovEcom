{
  "name": "@sovecom/storefront-next",
  "version": "0.0.1",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start -p 3001",
    "typecheck": "tsc --noEmit && tsc -p e2e/tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:default": "THEME=default playwright test",
    "test:e2e:boutique": "THEME=boutique playwright test",
    "test:e2e:update-snapshots": "THEME=default playwright test --update-snapshots",
    "test:e2e:update-snapshots:boutique": "THEME=boutique playwright test --update-snapshots",
    "lhci": "lhci autorun",
    "lhci:boutique": "lhci autorun --config=lighthouserc.boutique.json",
    "clean": "rm -rf dist .next"
  },
  "dependencies": {
    "@fontsource/ubuntu": "^5.2.8",
    "@sovecom/client-js": "workspace:*",
    "@sovecom/theme-sdk": "workspace:*",
    "@stripe/react-stripe-js": "^6.6.0",
    "@stripe/stripe-js": "^9.8.0",
    "lucide-react": "^1.17.0",
    "next": "^15.0.0",
    "next-intl": "^4.13.0",
    "react": "^19.2.7",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/typography": "^0.5.20",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.0",
    "autoprefixer": "^10.5.0",
    "ioredis": "^5.11.1",
    "jsdom": "^29.0.0",
    "postcss": "^8.5.15",
    "schema-dts": "^2.0.0",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.4.5",
    "vite": "^8.0.0",
    "vitest": "^4.0.0"
  }
}
