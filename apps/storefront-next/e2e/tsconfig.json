{
  // Dedicated tsconfig for the Playwright E2E specs. The storefront's main
  // tsconfig only `include`s `src/**` (Next build scope), and `lint`/`typecheck` are scoped to `src`
  // — so the E2E specs live OUTSIDE that surface and are type-checked here instead. Playwright's own
  // runner type-checks them at run time; this config makes them checkable in isolation too
  // (`tsc -p e2e/tsconfig.json --noEmit`) without dragging Node/Playwright globals into the app build.
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node"],
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "resolveJsonModule": true,
    "isolatedModules": true
  },
  "include": ["**/*.ts", "../playwright.config.ts"],
  "exclude": ["node_modules"]
}
